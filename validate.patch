+def validate_video(path: str) -> bool:
+    import os
+    import subprocess
+    if not os.path.exists(path):
+        return False
+    size = os.path.getsize(path)
+    if size < 100000:
+        return False
+    probe = subprocess.run(
+        [
+            "ffprobe",
+            "-v", "error",
+            "-show_entries",
+            "format=duration",
+            "-of", "default=noprint_wrappers=1:nokey=1",
+            path
+        ],
+        capture_output=True,
+        text=True
+    )
+    return probe.returncode == 0

