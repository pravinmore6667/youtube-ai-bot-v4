# ── AI Providers ─────────────────────────────────────────
GROQ_API_KEY=
MISTRAL_API_KEY=
GROK_API_KEY=
NVIDIA_API_KEY=

# ── Gemini API Keys (Supports automatic rotation & fallbacks) ──
GEMINI_API_KEY=
# You can add as many keys as you want by numbering them:
# GEMINI_API_KEY_1=
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=

# ── Always-Free Fallbacks ────────────────────────────────
POLLINATIONS_ENABLED=true
AI_HORDE_ENABLED=true

# ── Media APIs ────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ── YouTube ───────────────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Channel ───────────────────────────────────────────────
CHANNEL_NICHE=technology
CHANNEL_NAME=AI Channel
CHANNEL_LANGUAGE=en
CHANNEL_TONE=engaging and informative
TARGET_AUDIENCE=general audience

# ── Script settings ───────────────────────────────────────
TARGET_WORD_COUNT_MIN=800
TARGET_WORD_COUNT_MAX=1200
TARGET_DURATION_MIN=5
TARGET_DURATION_MAX=7

# ── Provider settings ─────────────────────────────────────
PROVIDER_ORDER=gemini,groq,mistral,grok
MAX_RETRIES=3
RETRY_DELAY=2

# ── Caching ───────────────────────────────────────────────
CACHE_ENABLED=true
CACHE_TTL_DAYS=7
CACHE_SIMILARITY=0.65

# ── Voice ─────────────────────────────────────────────────
TTS_VOICE_EN_MALE=en-US-GuyNeural
TTS_VOICE_EN_FEMALE=en-US-JennyNeural
TTS_VOICE_HI_MALE=hi-IN-MadhurNeural
TTS_VOICE_HI_FEMALE=hi-IN-SwaraNeural
TTS_VOICE_GENDER=male
TTS_RATE=+5%
TTS_VOLUME=+0%
TTS_PITCH=+0Hz

# ── Schedule ──────────────────────────────────────────────
UPLOAD_HOUR=10
UPLOAD_MINUTE=0
VIDEOS_PER_DAY=1

# ── Video ─────────────────────────────────────────────────
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
ENABLE_MUSIC=true
MUSIC_VOLUME=0.12
ENABLE_ZOOM_EFFECTS=true
MAX_WORKERS=4

# ── Dashboard ─────────────────────────────────────────────
PORT=5000
SECRET_KEY=change_me_in_production

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
